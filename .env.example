# API Ключ RouterAI для доступа к языковым моделям
ROUTERAI_KEY=your_routerai_key_here

# Настройки подключения к графовой базе данных Neo4j (например, Neo4j Aura)
NEO4J_URI=neo4j+s://your_neo4j_uri_here
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Идентификатор блокнота в Google NotebookLM (для работы populate_graph.py)
NOTEBOOK_ID=your_notebook_id_here

# Базовые настройки RouterAI (по умолчанию для РФ)
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
LLM_MODEL=deepseek/deepseek-chat
